#!/usr/bin/env bash
# BizBrain OS — SessionStart Hook
# Detects brain folder, generates zone-aware context, injects into Claude's system prompt.
# Runs on every session start, resume, clear, and compact.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

# --- Brain Discovery (shared) ---
source "${SCRIPT_DIR}/_discover-brain"

# --- JSON Escaping (pure bash, no sed/awk) ---
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# --- Check Dependencies ---
HAS_NODE=false
if command -v node &>/dev/null; then
  HAS_NODE=true
fi

# --- Generate Context ---
if [ -n "$BRAIN_PATH" ] && [ -d "$BRAIN_PATH" ]; then
  if [ "$HAS_NODE" = true ]; then
    # Convert MSYS paths for Node.js on Windows
    NODE_BRAIN_PATH=$(_to_node_path "$BRAIN_PATH")
    NODE_BIZBRAIN_ROOT=$(_to_node_path "$BIZBRAIN_ROOT")
    NODE_PLUGIN_ROOT=$(_to_node_path "$PLUGIN_ROOT")
    CONTEXT=$(node "${PLUGIN_ROOT}/scripts/generate-context.js" "$NODE_BRAIN_PATH" "$BIZBRAIN_MODE" "$BIZBRAIN_ZONE" "$NODE_BIZBRAIN_ROOT" 2>/dev/null || echo "# BizBrain OS\n\nError loading brain context. Run \`/brain status\` to diagnose.")
  else
    CONTEXT="# BizBrain OS\n\nBrain found at \`$BRAIN_PATH\` but Node.js is required for context generation.\nInstall Node.js 18+ and restart Claude Code.\n\n## Available Commands\n| Command | Description |\n|---------|-------------|\n| \`/brain status\` | Show brain status |\n| \`/todo\` | View tasks |\n| \`/knowledge <topic>\` | Load brain knowledge |"
  fi
else
  CONTEXT="# BizBrain OS\n\nNo brain folder found. Run \`/brain setup\` to scan your machine and create your knowledge brain.\n\n## Available Commands\n| Command | Description |\n|---------|-------------|\n| \`/brain setup\` | First-time setup |\n| \`/brain status\` | Show brain status |"
fi

ESCAPED_CONTEXT=$(escape_for_json "$CONTEXT")

# --- Update Session State ---
if [ -n "$BRAIN_PATH" ] && [ -d "$BRAIN_PATH/.bizbrain" ]; then
  TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date +"%Y-%m-%dT%H:%M:%SZ")
  echo "{\"lastSessionStart\":\"$TIMESTAMP\",\"sessionActive\":true,\"zone\":\"$BIZBRAIN_ZONE\",\"mode\":\"$BIZBRAIN_MODE\"}" > "$BRAIN_PATH/.bizbrain/session-state.json" 2>/dev/null || true
fi

# --- Client Sync Quick Check ---
# Runs quick sync to detect unread client messages (non-blocking, best-effort)
# Uses temp file because Node.js stdout piping is unreliable in Git Bash on Windows
CLIENT_ALERT_SECTION=""
if [ "$HAS_NODE" = true ]; then
  BB1_ROOT="C:/Users/Disruptors/Documents/Tech Integration Labs BB1"
  SYNC_ENGINE="${BB1_ROOT}/Operations/client-sync/sync-engine.js"
  if [ -f "$SYNC_ENGINE" ]; then
    SYNC_TMP=$(mktemp 2>/dev/null || echo "/tmp/bbos-sync-$$")
    node "$SYNC_ENGINE" --quick > "$SYNC_TMP" 2>/dev/null || true
    CLIENT_ALERTS=$(grep -i "Alert\|unread" "$SYNC_TMP" 2>/dev/null || true)
    rm -f "$SYNC_TMP" 2>/dev/null || true
    if [ -n "$CLIENT_ALERTS" ]; then
      ESCAPED_ALERTS=$(escape_for_json "$CLIENT_ALERTS")
      CLIENT_ALERT_SECTION="\\n\\n## Client Alerts\\n${ESCAPED_ALERTS}"
    fi
  fi
fi

# --- Update Check (once per day, 2s timeout, non-blocking) ---
UPDATE_NOTICE=""
PLUGIN_VERSION=""
if [ -f "${PLUGIN_ROOT}/.claude-plugin/plugin.json" ]; then
  PLUGIN_VERSION=$(grep '"version"' "${PLUGIN_ROOT}/.claude-plugin/plugin.json" 2>/dev/null | head -1 | sed 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
fi

if [ -n "$PLUGIN_VERSION" ] && [ -n "$BRAIN_PATH" ] && [ -d "$BRAIN_PATH" ]; then
  CACHE_DIR="$BRAIN_PATH/.bizbrain"
  CACHE_FILE="$CACHE_DIR/update-check.json"
  TODAY=$(date +"%Y-%m-%d" 2>/dev/null || true)
  SHOULD_CHECK=true

  # Only check once per day
  if [ -f "$CACHE_FILE" ]; then
    CACHED_DATE=$(grep '"checkedDate"' "$CACHE_FILE" 2>/dev/null | sed 's/.*"checkedDate"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || true)
    if [ "$CACHED_DATE" = "$TODAY" ]; then
      SHOULD_CHECK=false
      # Read cached result
      CACHED_LATEST=$(grep '"latestVersion"' "$CACHE_FILE" 2>/dev/null | sed 's/.*"latestVersion"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || true)
      if [ -n "$CACHED_LATEST" ] && [ "$CACHED_LATEST" != "$PLUGIN_VERSION" ]; then
        UPDATE_NOTICE="\\n\\n> **Update available:** BizBrain OS v${CACHED_LATEST} (you have v${PLUGIN_VERSION}). Run \`claude plugin update bizbrain-os\` to update."
      fi
    fi
  fi

  if [ "$SHOULD_CHECK" = true ]; then
    # Fetch latest tag from GitHub (2s timeout)
    LATEST_TAG=$(curl -s --connect-timeout 2 --max-time 2 \
      "https://api.github.com/repos/TechIntegrationLabs/bizbrain-os-plugin/tags?per_page=1" 2>/dev/null \
      | grep '"name"' | head -1 | sed 's/.*"name"[[:space:]]*:[[:space:]]*"v\?\([^"]*\)".*/\1/' || true)

    if [ -n "$LATEST_TAG" ]; then
      # Cache the result
      mkdir -p "$CACHE_DIR" 2>/dev/null || true
      echo "{\"checkedDate\":\"$TODAY\",\"latestVersion\":\"$LATEST_TAG\",\"installedVersion\":\"$PLUGIN_VERSION\"}" > "$CACHE_FILE" 2>/dev/null || true

      if [ "$LATEST_TAG" != "$PLUGIN_VERSION" ]; then
        UPDATE_NOTICE="\\n\\n> **Update available:** BizBrain OS v${LATEST_TAG} (you have v${PLUGIN_VERSION}). Run \`claude plugin update bizbrain-os\` to update."
      fi
    fi
  fi
fi

# --- Output Context Injection ---
SESSION_CONTEXT="<bizbrain-os-context>\\n${ESCAPED_CONTEXT}${CLIENT_ALERT_SECTION}${UPDATE_NOTICE}\\n</bizbrain-os-context>"

cat <<EOF
{
  "additional_context": "${SESSION_CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${SESSION_CONTEXT}"
  }
}
EOF

exit 0
